# LLM 프로바이더
LLM_PROVIDER=lmstudio

# LMStudio (OpenAI 호환)
LMSTUDIO_API_URL=http://host.docker.internal:1234/v1
LMSTUDIO_MODEL=google/gemma-4-e4b

# Ollama (대체)
OLLAMA_API_URL=http://ollama:11434
OLLAMA_MODEL=gemma:4b

# API 키 (선택사항)
CLAUDE_API_KEY=
GOOGLE_GEMINI_API_KEY=
COHERE_API_KEY=
HF_API_KEY=

# 서버 설정
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=pronunciation_master
DB_USER=dev
DB_PASSWORD=devpass

# JWT
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=24h

# Stripe (test keys)
STRIPE_PUBLIC_KEY=pk_test_placeholder
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# 데이터베이스 (legacy)
DATABASE_URL=postgresql://dev:devpass@postgres:5432/pronunciation_master

# 로깅
LOG_LEVEL=debug
