# Production — copy to .env.production and fill real values

NODE_ENV=production

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=pronunciation_master
DB_USER=pronunciation
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT
JWT_SECRET=CHANGE_ME_32_CHAR_RANDOM_SECRET
JWT_EXPIRES_IN=24h

# Stripe Live
STRIPE_PUBLIC_KEY=pk_live_YOUR_KEY
STRIPE_SECRET_KEY=sk_live_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET

# LLM (LMStudio on host)
LLM_PROVIDER=lmstudio
LMSTUDIO_API_URL=http://host.docker.internal:1234/v1
LMSTUDIO_MODEL=google/gemma-4-e4b

# Frontend build
VITE_API_URL=https://api.yourdomain.com
